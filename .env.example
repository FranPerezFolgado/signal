# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# PostgreSQL
DATABASE_URL=postgresql://signal:signal@localhost:5432/signal

# Last.fm — get a free API key at https://www.last.fm/api/account/create
LASTFM_API_KEY=your_api_key_here
LASTFM_USERNAME=your_lastfm_username

# Spotify (normalizer + enricher)
SPOTIFY_CLIENT_ID=your_client_id_here
SPOTIFY_CLIENT_SECRET=your_client_secret_here
SPOTIFY_REFRESH_TOKEN=your_refresh_token_here

# Enricher resilience
SPOTIFY_RATE_LIMIT_PER_30S=180
CIRCUIT_BREAKER_FAILURE_THRESHOLD=5
CIRCUIT_BREAKER_TIMEOUT_S=60.0
BACKOFF_BASE_S=1.0
BACKOFF_MAX_S=30.0
LASTFM_FALLBACK_ENABLED=true

# Ingester tuning
LASTFM_POLL_INTERVAL_SECONDS=60

# Artist classification
INITIAL_HIGH_PRIORITY_PLAYS=20
AUTO_FOLLOW_PLAYS=3

# Scorer weights (v2: genre_novelty + popularity_norm, audio features removed)
W1=0.6
W2=0.4
HP_BONUS=1.2

# Logging
LOG_LEVEL=INFO
